rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // FUNCIONES AUXILIARES DE SEGURIDAD (RBAC)
    // ==========================================

    function hasUserRecord() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) ||
             exists(/databases/$(database)/documents/artifacts/mi-app-asistencia/public/data/usuarios/$(request.auth.uid));
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data
        : get(/databases/$(database)/documents/artifacts/mi-app-asistencia/public/data/usuarios/$(request.auth.uid)).data;
    }

    function isAuthed() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthed() && (
        (request.auth.token.email in ['leomotto@gmail.com', 'leopoldo.motto@bue.edu.ar']) ||
        (hasUserRecord() && (getUserData().rol == 'SUPERADMIN' || getUserData().superadmin == true))
      );
    }

    // Un Admin puede serlo a nivel global o a nivel de la institución (tenant)
    // O si es SUPERADMIN, hereda permisos.
    function isAdmin(tenantId) {
      return isAuthed() && (
        isSuperAdmin() || 
        (hasUserRecord() && (
          getUserData().rol == 'ADMIN' ||
          (tenantId != null && 'escuelas' in getUserData() && tenantId in getUserData().escuelas && getUserData().escuelas[tenantId].rol == 'ADMIN')
        ))
      );
    }

    function isDocente(tenantId) {
      return isAuthed() && hasUserRecord() && (
        isAdmin(tenantId) ||
        getUserData().rol == 'DOCENTE' ||
        (tenantId != null && 'escuelas' in getUserData() && tenantId in getUserData().escuelas && getUserData().escuelas[tenantId].rol == 'DOCENTE')
      );
    }

    function docenteTieneCurso(tenantId, curso) {
      return isDocente(tenantId) && (
        isAdmin(tenantId) ||
        (tenantId != null && 'escuelas' in getUserData() && tenantId in getUserData().escuelas && 'materias' in getUserData().escuelas[tenantId] && getUserData().escuelas[tenantId].materias.hasAny([curso])) ||
        ('materias' in getUserData() && getUserData().materias.hasAny([curso]))
      );
    }

    // La planilla de un curso está bloqueada si existe su doc de lock con locked == true.
    // Aplica a TODOS los roles: un admin debe desbloquear primero para poder editar.
    function planillaBloqueada(tenantId, curso) {
      return exists(/databases/$(database)/documents/instituciones/$(tenantId)/evaluaciones_locks/$(curso)) &&
             get(/databases/$(database)/documents/instituciones/$(tenantId)/evaluaciones_locks/$(curso)).data.locked == true;
    }

    // ==========================================
    // REGLAS GLOBALES (Root Collections)
    // ==========================================

    match /usuarios/{userId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.auth.uid == userId && (
                      (request.auth.token.email in ['leomotto@gmail.com', 'leopoldo.motto@bue.edu.ar']) ||
                      (request.resource.data.keys().hasAll(['email', 'rol']) && request.resource.data.rol == 'PENDIENTE')
                    );
      allow update: if isAuthed() && (
        isSuperAdmin() || isAdmin(null) ||
        (request.auth.uid == userId && request.auth.token.email in ['leomotto@gmail.com', 'leopoldo.motto@bue.edu.ar']) ||
        (
          request.auth.uid == userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nombre', 'escuelas'])
        )
      );
      allow delete: if isAdmin(null);
    }

    match /escuelas/{docId} {
      allow read: if isAuthed();
      allow write: if isSuperAdmin();
    }

    match /instituciones/{docId} {
      allow read: if isAuthed();
      allow write: if isSuperAdmin();
    }

    match /materias/{docId} {
      allow read, write: if isSuperAdmin();
    }
    match /estudiantes/{docId} {
      allow read, write: if isSuperAdmin();
    }
    match /asistencias/{docId} {
      allow read, write: if isSuperAdmin();
    }
    match /evaluaciones/{docId} {
      allow read, write: if isSuperAdmin();
    }
    match /evaluaciones_locks/{docId} {
      allow read, write: if isSuperAdmin();
    }
    match /horarios/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // Compatibilidad para `getPath` con prefijo artifacts
    match /artifacts/mi-app-asistencia/public/data/escuelas/{docId} {
      allow read: if isAuthed();
      allow write: if isSuperAdmin();
    }
    match /artifacts/mi-app-asistencia/public/data/usuarios/{docId} {
      allow read: if isAuthed();
      allow write: if isSuperAdmin();
    }
    match /artifacts/mi-app-asistencia/public/data/instituciones/{docId} {
      allow read: if isAuthed();
      allow write: if isSuperAdmin();
    }

    // ==========================================
    // REGLAS TENANT (Subcollections of instituciones)
    // ==========================================
    
    match /instituciones/{tenantId}/materias/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin(tenantId);
    }

    match /instituciones/{tenantId}/horarios/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin(tenantId);
    }

    match /instituciones/{tenantId}/config/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin(tenantId);
    }

    match /instituciones/{tenantId}/evaluaciones_locks/{docId} {
      allow read:  if isAuthed();
      // Docente puede BLOQUEAR su curso, pero solo un Admin puede desbloquear o borrar el lock.
      allow create, update: if isAdmin(tenantId) ||
                               (isDocente(tenantId) && docenteTieneCurso(tenantId, docId) && request.resource.data.locked == true);
      allow delete: if isAdmin(tenantId);
    }

    match /instituciones/{tenantId}/estudiantes/{docId} {
      allow read:  if isDocente(tenantId);
      allow write: if isAdmin(tenantId);
    }

    match /instituciones/{tenantId}/asistencias/{docId} {
      allow read, write: if isAdmin(tenantId);
      allow read:   if isDocente(tenantId) &&
                       resource != null &&
                       docenteTieneCurso(tenantId, resource.data.curso);
      allow create: if isDocente(tenantId) &&
                       docenteTieneCurso(tenantId, request.resource.data.curso);
      allow update: if isDocente(tenantId) &&
                       resource != null &&
                       docenteTieneCurso(tenantId, resource.data.curso) &&
                       docenteTieneCurso(tenantId, request.resource.data.curso);
      allow delete: if isDocente(tenantId) &&
                       resource != null &&
                       docenteTieneCurso(tenantId, resource.data.curso);
    }

    match /instituciones/{tenantId}/evaluaciones/{docId} {
      allow read: if isAdmin(tenantId);
      allow read: if isDocente(tenantId) &&
                     resource != null &&
                     docenteTieneCurso(tenantId, resource.data.materia);
      // Escrituras bloqueadas para todos (incluido admin) si la planilla del curso está bloqueada.
      allow create: if !planillaBloqueada(tenantId, request.resource.data.materia) && (
                       isAdmin(tenantId) ||
                       (isDocente(tenantId) && docenteTieneCurso(tenantId, request.resource.data.materia))
                    );
      allow update: if !planillaBloqueada(tenantId, resource.data.materia) &&
                       !planillaBloqueada(tenantId, request.resource.data.materia) && (
                       isAdmin(tenantId) ||
                       (isDocente(tenantId) &&
                        docenteTieneCurso(tenantId, resource.data.materia) &&
                        docenteTieneCurso(tenantId, request.resource.data.materia))
                    );
      allow delete: if !planillaBloqueada(tenantId, resource.data.materia) && (
                       isAdmin(tenantId) ||
                       (isDocente(tenantId) && docenteTieneCurso(tenantId, resource.data.materia))
                    );
    }
  }
}
