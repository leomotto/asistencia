rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // FUNCIONES AUXILIARES DE SEGURIDAD (RBAC)
    // ==========================================

    function hasUserRecord() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) ||
             exists(/databases/$(database)/documents/artifacts/mi-app-asistencia/public/data/usuarios/$(request.auth.uid));
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data
        : get(/databases/$(database)/documents/artifacts/mi-app-asistencia/public/data/usuarios/$(request.auth.uid)).data;
    }

    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed() && hasUserRecord() && getUserData().rol == 'ADMIN';
    }

    function isSuperAdmin() {
      return isAuthed() && hasUserRecord() && (getUserData().rol == 'SUPERADMIN' || getUserData().superadmin == true);
    }

    // Docente O Admin — tienen acceso operativo
    function isDocente() {
      return isAuthed() && hasUserRecord() && (getUserData().rol == 'DOCENTE' || getUserData().rol == 'ADMIN');
    }

    // Docente con materia específica asignada en su perfil
    function docenteTieneCurso(curso) {
      return isDocente() && getUserData().materias.hasAny([curso]);
    }

    // ==========================================
    // REGLAS GLOBALES (Root Collections)
    // ==========================================

    match /usuarios/{userId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.auth.uid == userId &&
                    request.resource.data.keys().hasAll(['email', 'rol']) &&
                    request.resource.data.rol == 'PENDIENTE';
      allow update: if isAuthed() && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nombre'])
        )
      );
      allow delete: if isAdmin();
    }

    match /escuelas/{docId} {
      allow read: if isAuthed();
      allow write: if isSuperAdmin();
    }

    match /instituciones/{docId} {
      allow read: if isAuthed();
      allow write: if isSuperAdmin();
    }

    // ==========================================
    // REGLAS TENANT (Subcollections of instituciones)
    // ==========================================
    
    match /instituciones/{tenantId}/materias/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    match /instituciones/{tenantId}/horarios/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    match /instituciones/{tenantId}/config/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    match /instituciones/{tenantId}/evaluaciones_locks/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin() || (isDocente() && docenteTieneCurso(docId));
    }

    match /instituciones/{tenantId}/estudiantes/{docId} {
      allow read:  if isDocente();
      allow write: if isAdmin();
    }

    match /instituciones/{tenantId}/asistencias/{docId} {
      allow read, write: if isAdmin();
      allow read:   if isDocente() &&
                       resource != null &&
                       docenteTieneCurso(resource.data.curso);
      allow create: if isDocente() &&
                       docenteTieneCurso(request.resource.data.curso);
      allow update: if isDocente() &&
                       resource != null &&
                       docenteTieneCurso(resource.data.curso) &&
                       docenteTieneCurso(request.resource.data.curso);
      allow delete: if isDocente() &&
                       resource != null &&
                       docenteTieneCurso(resource.data.curso);
    }

    match /instituciones/{tenantId}/evaluaciones/{docId} {
      allow read, write: if isAdmin();
      allow read: if isDocente() &&
                     resource != null &&
                     docenteTieneCurso(resource.data.materia);
      allow create: if isDocente() &&
                       docenteTieneCurso(request.resource.data.materia);
      allow update: if isDocente() &&
                       resource != null &&
                       docenteTieneCurso(resource.data.materia) &&
                       docenteTieneCurso(request.resource.data.materia);
      allow delete: if isDocente() &&
                       resource != null &&
                       docenteTieneCurso(resource.data.materia);
    }
  }
}
