rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // FUNCIONES AUXILIARES DE SEGURIDAD (RBAC)
    // ==========================================

    function hasUserRecord() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) ||
             exists(/databases/$(database)/documents/artifacts/mi-app-asistencia/public/data/usuarios/$(request.auth.uid));
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data
        : get(/databases/$(database)/documents/artifacts/mi-app-asistencia/public/data/usuarios/$(request.auth.uid)).data;
    }

    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed() && hasUserRecord() && getUserData().rol == 'ADMIN';
    }

    function isSuperAdmin() {
      return isAuthed() && hasUserRecord() && (getUserData().rol == 'SUPERADMIN' || getUserData().superadmin == true);
    }

    // Docente O Admin — tienen acceso operativo
    function isDocente() {
      return isAuthed() && hasUserRecord() && (getUserData().rol == 'DOCENTE' || getUserData().rol == 'ADMIN');
    }

    // Docente con materia específica asignada en su perfil
    function docenteTieneCurso(curso) {
      return isDocente() && getUserData().materias.hasAny([curso]);
    }

    // ==========================================
    // REGLAS PARA LA COLECCIÓN: usuarios
    // ==========================================
    match /{path=**}/usuarios/{userId} {
      allow read: if isAuthed();

      // Nuevos usuarios solo pueden auto-registrarse como PENDIENTE.
      // Para promover el primer ADMIN usar Firebase Console.
      allow create: if isAuthed() && request.auth.uid == userId &&
                    request.resource.data.keys().hasAll(['email', 'rol']) &&
                    request.resource.data.rol == 'PENDIENTE';

      // Un usuario solo puede actualizar su propio nombre; rol y materias solo el ADMIN
      allow update: if isAuthed() && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nombre'])
        )
      );

      allow delete: if isAdmin();
    }

    // ==========================================
    // REGLAS PARA COLECCIONES MULTI-TENANT: escuelas / instituciones
    // ==========================================
    match /{path=**}/escuelas/{docId} {
      allow read: if isAuthed();
      allow write: if isSuperAdmin();
    }

    match /{path=**}/instituciones/{docId} {
      allow read: if isAuthed();
      allow write: if isSuperAdmin();
    }

    // ==========================================
    // REGLAS PARA COLECCIONES: materias y horarios
    // (solo secretaría/admin puede modificar la estructura curricular)
    // ==========================================
    match /{path=**}/materias/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    match /{path=**}/horarios/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    match /{path=**}/config/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    match /{path=**}/evaluaciones_locks/{docId} {
      allow read:  if isAuthed();
      // Un docente puede bloquear el curso asignado; el admin puede bloquear y desbloquear cualquier curso
      allow write: if isAdmin() || (isDocente() && docenteTieneCurso(docId));
    }

    // ==========================================
    // REGLAS PARA COLECCIÓN: estudiantes
    // Lectura: Docentes y Admin (para tomar lista).
    // Escritura: SOLO Admin (inscripciones, bajas, fusiones).
    // ==========================================
    match /{path=**}/estudiantes/{docId} {
      allow read:  if isDocente();
      allow write: if isAdmin();
    }

    // ==========================================
    // REGLAS PARA COLECCIÓN: asistencias
    // Admin: acceso total.
    // Docente: solo puede leer y escribir registros de SUS materias asignadas.
    // ==========================================
    match /{path=**}/asistencias/{docId} {

      // Admin: lectura y escritura irrestrictas
      allow read:   if isAdmin();
      allow write:  if isAdmin();

      // Docente — lectura: solo asistencias del curso que dicta
      // (para list queries, resource.data.curso aplica a cada doc del resultado)
      allow read:   if isDocente() &&
                       resource != null &&
                       docenteTieneCurso(resource.data.curso);

      // Docente — escritura: solo crear/actualizar registros en sus materias
      allow create: if isDocente() &&
                       docenteTieneCurso(request.resource.data.curso);
      allow update: if isDocente() &&
                       resource != null &&
                       docenteTieneCurso(resource.data.curso) &&
                       docenteTieneCurso(request.resource.data.curso);

      // Docente — borrado: solo en sus materias (raro, pero cubierto)
      allow delete: if isDocente() &&
                       resource != null &&
                       docenteTieneCurso(resource.data.curso);
    }

    // ==========================================
    // REGLAS PARA COLECCIÓN: evaluaciones
    // Admin: acceso total.
    // Docente: solo puede leer y escribir calificaciones de sus materias asignadas.
    // ==========================================
    match /{path=**}/evaluaciones/{docId} {
      // Admin: lectura y escritura total
      allow read, write: if isAdmin();

      // Docente — lectura: solo si tiene asignada la materia del registro
      allow read: if isDocente() &&
                     resource != null &&
                     docenteTieneCurso(resource.data.materia);

      // Docente — escritura (crear, actualizar): solo para sus materias
      allow create: if isDocente() &&
                       docenteTieneCurso(request.resource.data.materia);
      allow update: if isDocente() &&
                       resource != null &&
                       docenteTieneCurso(resource.data.materia) &&
                       docenteTieneCurso(request.resource.data.materia);

      // Docente — borrado: restringido (solo admin o docente si el curso le pertenece)
      allow delete: if isDocente() &&
                       resource != null &&
                       docenteTieneCurso(resource.data.materia);
    }

  }
}
